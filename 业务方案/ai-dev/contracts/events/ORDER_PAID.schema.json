{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scm.local/schemas/events/ORDER_PAID.v1.json",
  "title": "ORDER_PAID data",
  "type": "object",
  "required": ["trade_no", "order_no", "buyer_id", "channel", "paid_amount", "currency", "pay_time", "lines"],
  "properties": {
    "trade_no": { "type": "string" },
    "order_no": { "type": "string" },
    "buyer_id": { "type": "string" },
    "channel": { "type": "string" },
    "paid_amount": { "type": "string", "pattern": "^\\d+(\\.\\d{1,4})?$" },
    "currency": { "type": "string", "const": "CNY" },
    "pay_time": { "type": "string", "format": "date-time" },
    "lines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["sku_id", "qty", "warehouse_id"],
        "properties": {
          "line_id": { "type": "integer" },
          "sku_id": { "type": "string" },
          "qty": { "type": "string" },
          "warehouse_id": { "type": "string" }
        }
      }
    }
  }
}
