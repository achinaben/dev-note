{
  "realm": "scm",
  "enabled": true,
  "clients": [
    {
      "clientId": "scm-gateway",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:8080/*"],
      "webOrigins": ["*"],
      "defaultClientScopes": ["profile", "email", "roles"]
    }
  ],
  "users": [
    {
      "username": "e2e-user",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "e2e-pass",
          "temporary": false
        }
      ],
      "realmRoles": ["default-roles-scm"],
      "clientRoles": {
        "scm-gateway": ["oms.write", "wms.write"]
      }
    }
  ]
}
