{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["code", "message", "request_id", "data"],
  "properties": {
    "code": { "type": "string" },
    "message": { "type": "string" },
    "request_id": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["trade_no", "orders"],
      "properties": {
        "trade_no": { "type": "string", "pattern": "^T" },
        "orders": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["order_no", "pay_amount"],
            "properties": {
              "order_no": { "type": "string", "pattern": "^O" },
              "pay_amount": { "type": "string" },
              "status": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
