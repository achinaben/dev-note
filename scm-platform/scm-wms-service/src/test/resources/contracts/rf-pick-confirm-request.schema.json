{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["task_no", "operation_id", "lines"],
  "properties": {
    "task_no": { "type": "string" },
    "operation_id": { "type": "string" },
    "outbound_no": { "type": "string" },
    "lines": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "object" }
    }
  }
}
